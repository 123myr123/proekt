FROM python:3-12-slim

ENV PYTHONDONTWRITEBYTECODE = 1 \
    PYTHONNUNBUFFERED = 1

RUN apt-get ubdate && apt-get install -y --no -install-recommendes \
    sglite3 \
    curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspase

COPY app /workspase/app
COPY sql /workspase/sql
COPY entrypoint.sh /entrypoint.sh

RUN pip install --no--cache-dir -r / workspase/app/requirements.txt
    && mkdir -p /workspase/data

EXPOSE 8090